{
    "geode": "2.0.0",
    "id": "iwantgrandpademon.xxlify",
    "name": "XXLify",
    "version": "1.3.5",
    "description": "Adds XXL length labels to levels.",
    "authors": [
        "cvolton",
        "IwantgrandpademonOnIos"
    ],
    "platforms": [
        "windows",
        "macos",
        "android",
        "ios"
    ],
    "settings": {
        "maximum-xs": {
            "type": "int",
            "default": 20
        },
        "use-power-notation": {
            "type": "bool",
            "default": false
        },
        "xxl-plus": {
            "type": "bool",
            "default": true
        },
        "xxl-scaling": {
            "type": "float",
            "default": 1.5
        },
        "use-color": {
            "type": "bool",
            "default": false
        },
        "maximum-color": {
            "type": "int",
            "default": 5
        },
        "label-color": {
            "type": "color",
            "default": "255,255,255"
        },
        "long-plus": {
            "type": "bool",
            "default": true
        }
    }
}
